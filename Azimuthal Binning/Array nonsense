import numpy as np 

p=np.empty((3,2))
q=np.array([1,1])
w=np.array([1,2])
e=np.array([1,3])
p[0]=e
p[1]=q
p[2]=w

def binning(m):
    Binned=np.empty([3,2])
    for i in range(0,2):
        entry=m[i]
        entry_1=m[i+1]

        if entry[0] == entry_1[0]: 
            amp= entry[1] + entry[1]
            k_amp=np.array([entry[0],amp])
            Binned[i]=k_amp
            #m=np.delete(m, i+1, axis=0)


        else:
            Binned[i]=entry
    return Binned

print(binning(p))