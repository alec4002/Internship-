import numpy as np
import matplotlib.pyplot as plt


#This code is just to make the matrox i will be working with, it is arbitry. 
def calculate_2dft(input):
    ft = np.fft.ifftshift(input)
    ft = np.fft.fft2(ft)
    return np.fft.fftshift(ft)

