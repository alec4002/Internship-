#an important note; fft is for discrete data. So i need to make a discrete approximation of a circle. Easiest way is probs to 
#define a continuous function and then pass over a discrete number of values. 

def circ(x,y):
    return x**2 + y**2 - 1 

plt.figure() 
plt.imshow(np.arange(-5,5,0.1),circ(np.arange(-5,5,0.1)))
plt.show() 
