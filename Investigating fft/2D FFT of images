image=plt.imread(f'C:\Internship\Internship-\Investigating fft\Rect 2.jpg')

ft= np.fft.fft2(image)
ft=np.fft.fftshift(ft)
ft_squared=(np.abs(ft))**2

Sample_frequencies=np.fft.fftfreq(len(ft_squared))
Sample_frequencies=Sample_frequencies*(-1)

plt.figure()
plt.hist(((ft_squared.ravel())), np.sort(Sample_frequencies))#,density=True)
plt.yscale('log')
plt.xlim(0)
plt.show()

