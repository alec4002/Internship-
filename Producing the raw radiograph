import pyhdf 
from pyhdf.SD import SD, SDC
import matplotlib.pyplot as plt
import numpy as np
import matplotlib.colors as colors

#Emma's code to load the data into python
def load_hdf_BCcor(shotNum, ccdNum, timNum):
    file_name = f"XRFC3CCD-xrfc3_t4_117321.hdf"

    hdf_file  = SD(file_name, SDC.READ)
    sds_obj   = hdf_file.select(0)
    data      = sds_obj.get()
    return data[0] - data[1]

